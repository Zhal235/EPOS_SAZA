# =============================================
# EPOS SAZA - PRODUCTION ENVIRONMENT
# =============================================
# Copy this file to .env in production server
# and update all values with actual production data

# Application
APP_NAME="EPOS SAZA"
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_HERE
APP_DEBUG=false
APP_URL=https://epos-simpels.saza.sch.id
APP_VERSION=1.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# =============================================
# PERFORMANCE OPTIMIZATION
# =============================================

# Logging - Reduce verbosity in production
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Cache - CRITICAL: Use Redis for performance
CACHE_DRIVER=redis
CACHE_PREFIX=epos_cache

# Session - Use Redis for better performance
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Queue - Use Redis
QUEUE_CONNECTION=redis

# Broadcasting
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# =============================================
# DATABASE CONFIGURATION
# =============================================

DB_CONNECTION=mysql
DB_HOST=epos-db
DB_PORT=3306
DB_DATABASE=epos_saza_production
DB_USERNAME=epos_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# =============================================
# REDIS CONFIGURATION
# =============================================

REDIS_CLIENT=phpredis
REDIS_HOST=epos-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================
# MAIL CONFIGURATION
# =============================================

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@saza.sch.id
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@saza.sch.id"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================
# SIMPELS API CONFIGURATION
# =============================================

# SIMPELS 2.0 API
# PRODUCTION: https://api-simpels.saza.sch.id/api/v1/wallets
SIMPELS_API_URL=https://api-simpels.saza.sch.id/api/v1/wallets
SIMPELS_API_TIMEOUT=30
SIMPELS_API_KEY=YOUR_PRODUCTION_API_KEY_HERE

# Shared secret untuk webhook dari SIMPELS
EPOS_WEBHOOK_SECRET=GENERATE_STRONG_SECRET_HERE

# =============================================
# DOCKER SPECIFIC (for docker-compose)
# =============================================

APP_DOMAIN=epos-simpels.saza.sch.id

# =============================================
# OPTIMIZATION FLAGS
# =============================================

# View compilation path (for Docker)
VIEW_COMPILED_PATH=/var/www/html/storage/framework/views

# =============================================
# SECURITY NOTE
# =============================================
# 1. Generate new APP_KEY: php artisan key:generate
# 2. Use strong DB_PASSWORD (min 16 chars, mixed case, numbers, symbols)
# 3. Generate strong EPOS_WEBHOOK_SECRET
# 4. Get SIMPELS_API_KEY from SAZA IT team
# 5. NEVER commit this file to git!
